{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "eslint.d.ts",
    "src/renderer/src/env.d.ts",
    "src/renderer/src/index.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/**/*.d.ts",
    "src/shared/**/*",
    "src/shared/"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@/*": [
        "src/renderer/src/*"
      ],
      "@xyflow/react": [
        "node_modules/@xyflow/react/dist/esm/index.d.ts"
      ],
      "@xyflow/react/dist/src/*": [
        "node_modules/@xyflow/react/dist/esm/*"
      ]
    }
  }
}
